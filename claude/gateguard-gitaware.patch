+// --- Git-repo airbag relaxation (operator patch) ---
+// When an operation targets a path inside a git work tree, the working copy is
+// recoverable (git history + per-tool agentgit snapshots), so the routine-Bash
+// and first-touch Edit/Write *friction* gates are skipped there. The
+// DESTRUCTIVE gate is intentionally NOT relaxed: `rm -rf`, force-push, and
+// `drop table` can destroy untracked files or history that git does not bring
+// back. Opt-in: enable with GATEGUARD_GIT_REPO_RELAX in {1,true,on,enabled,yes}.
+const gitRepoCache = new Map();
+
+function isGitRepoRelaxEnabled() {
+  return ECC_ENABLE_VALUES.has(normalizeEnvValue(process.env.GATEGUARD_GIT_REPO_RELAX));
+}
+
+// Trust the harness read-before-edit guarantee (operator patch). The Claude Code
+// Edit/MultiEdit tools refuse to run unless the file was already Read, and Write
+// refuses to overwrite an existing file unless it was Read — so for those cases
+// the "investigation" the gate forces is already guaranteed, and a deny just makes
+// the model re-compose (and re-pay for) the whole edit payload. When enabled, skip
+// the gate for edits and existing-file writes; only brand-NEW file creation (no
+// prior read possible) is still gated. Opt-in: GATEGUARD_TRUST_READ_BEFORE_EDIT in
+// {1,true,on,enabled,yes}.
+function isReadBeforeEditTrusted() {
+  return ECC_ENABLE_VALUES.has(normalizeEnvValue(process.env.GATEGUARD_TRUST_READ_BEFORE_EDIT));
+}
+
+function isInsideGitRepo(dir) {
+  const target = String(dir || '').trim() || process.cwd();
+  if (gitRepoCache.has(target)) {
+    return gitRepoCache.get(target);
+  }
+  let inside = false;
+  try {
+    const out = execFileSync('git', ['-C', target, 'rev-parse', '--is-inside-work-tree'], {
+      timeout: 500,
+      stdio: ['ignore', 'pipe', 'ignore'],
+      encoding: 'utf8'
+    });
+    inside = out.trim() === 'true';
+  } catch (_) {
+    inside = false; // not a repo, git missing, or path gone — fail closed (gate stays on)
+  }
+  gitRepoCache.set(target, inside);
+  return inside;
+}
