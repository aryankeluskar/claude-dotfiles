{
  "env": {
    "GATEGUARD_GIT_REPO_RELAX": "1",
    "ECC_DISABLED_HOOKS": "pre:bash:gateguard-fact-force",
    "GATEGUARD_TRUST_READ_BEFORE_EDIT": "1"
  },
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$HOME/node_modules/agentgit/src/index.ts\" ] && \"$HOME/.bun/bin/bun\" \"$HOME/node_modules/agentgit/src/index.ts\" snap || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/dotfiles-claude/pull.sh\" ] && \"$HOME/dotfiles-claude/pull.sh\" >/dev/null 2>&1 &",
            "timeout": 5,
            "statusMessage": "claude config auto-pull"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/save-last-response.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/assume_yes_stop.py\"",
            "timeout": 10,
            "statusMessage": "assume-yes stop hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/assume_yes_stop.py\" --reset",
            "timeout": 5,
            "statusMessage": "reset assume-yes rounds"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 \"$HOME/.claude/statusline.py\""
  },
  "enabledPlugins": {
    "safety-net@cc-marketplace": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "hive-skills@hive": true,
    "imessage@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "ecc@ecc": true
  },
  "extraKnownMarketplaces": {
    "hive": {
      "source": {
        "source": "github",
        "repo": "rllm-org/hive"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "ecc": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    }
  }
}
